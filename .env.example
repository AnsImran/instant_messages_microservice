# -----------------------------------------------------------------------------
# Instant Messages Microservice — environment file.
#
# Copy this file to `.env` (or mount it from a Docker secret) and fill in
# your values. Path overrides:
#
#   ENV_FILE     - alternate path to this .env file
#   CONFIG_FILE  - alternate path to config/app.yaml
#
# Changes here take effect after a server restart, or via:
#
#   POST /api/v1/admin/reload-config   (with X-Admin-Key header)
# -----------------------------------------------------------------------------

# Fallback Teams webhook used when a request omits both webhook_url and webhook_target.
DEFAULT_TEAMS_WEBHOOK_URL=

# Shared secret required on the X-Admin-Key header for admin endpoints.
# Leave empty to disable admin endpoints entirely (they will return 503).
ADMIN_API_KEY=

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=pretty          # 'json' for production, 'pretty' for local dev

# CORS — comma separated list; '*' to allow everything (default).
# Example: CORS_ALLOW_ORIGINS=["https://app.example.com","https://ops.example.com"]

# HTTP client
HTTPX_TIMEOUT_SECONDS=15
WEBHOOK_MAX_RETRIES=2
